  "description": "SwiftPay fintech wallet payments frontend.",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --turbopack",
    "dev:clean": "node --input-type=module -e \"import { rmSync } from 'node:fs'; try { rmSync('.next', { recursive: true, force: true }); } catch {}\" && next dev --turbopack",
