{
  "name": "swiftpay",
  "version": "1.0.0",
  "description": "SwiftPay monorepo.",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @swiftpay/web",
    "dev:clean": "npm run dev:clean --workspace @swiftpay/web",
    "build": "npm run build --workspace @swiftpay/web",
    "start": "npm run start --workspace @swiftpay/web",
    "typecheck": "npm run typecheck --workspace @swiftpay/web",
    "test": "npm run test --workspaces --if-present",
    "contracts:compile": "npm run compile --workspace @swiftpay/contracts",
    "contracts:deploy": "npm run deploy --workspace @swiftpay/contracts",
    "contracts:deploy-escrow": "npm run deploy:escrow --workspace @swiftpay/contracts",
    "contracts:deploy-swiftbatch": "npm run deploy:swiftbatch --workspace @swiftpay/contracts",
    "create-wallet": "npm run create-wallet --workspace @swiftpay/scripts",
    "batch-wallets": "npm run batch-wallets --workspace @swiftpay/scripts",
    "send-tokens": "npm run send-tokens --workspace @swiftpay/scripts",
    "generate-entity-secret": "npm run generate-entity-secret --workspace @swiftpay/scripts",
    "bridge": "npm run bridge --workspace @swiftpay/scripts",
    "swap": "npm run swap --workspace @swiftpay/scripts",
    "send": "npm run send --workspace @swiftpay/scripts"
  },
  "allowScripts": {
    "utf-8-validate@5.0.10": true,
    "utf-8-validate@6.0.6": true,
    "bufferutil@4.1.0": true,
    "esbuild@0.28.0": true,
    "keccak@3.0.4": true,
    "protobufjs@7.6.1": true,
    "sharp@0.34.5": true
  }
}
