{
  "name": "swiftpay",
  "version": "1.0.0",
  "description": "SwiftPay monorepo.",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "packageManager": "pnpm@10.12.1",
  "engines": {
    "node": ">=20",
    "pnpm": ">=10.12.1"
  },
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "dev": "pnpm --filter @swiftpay/web dev",
    "dev:clean": "pnpm --filter @swiftpay/web dev:clean",
    "build": "pnpm --filter @swiftpay/web build",
    "start": "pnpm --filter @swiftpay/web start",
    "typecheck": "pnpm --filter @swiftpay/web typecheck",
    "test": "pnpm -r --if-present test",
    "contracts:compile": "pnpm --filter @swiftpay/contracts compile",
    "contracts:deploy": "pnpm --filter @swiftpay/contracts deploy",
    "contracts:deploy-escrow": "pnpm --filter @swiftpay/contracts deploy:escrow",
    "contracts:deploy-swiftbatch": "pnpm --filter @swiftpay/contracts deploy:swiftbatch",
    "contracts:deploy-swiftrecurepay": "pnpm --filter @swiftpay/contracts deploy:swiftrecurepay",
    "create-wallet": "pnpm --filter @swiftpay/scripts create-wallet",
    "batch-wallets": "pnpm --filter @swiftpay/scripts batch-wallets",
    "send-tokens": "pnpm --filter @swiftpay/scripts send-tokens",
    "generate-entity-secret": "pnpm --filter @swiftpay/scripts generate-entity-secret",
    "bridge": "pnpm --filter @swiftpay/scripts bridge",
    "swap": "pnpm --filter @swiftpay/scripts swap",
    "send": "pnpm --filter @swiftpay/scripts send"
  }
}
